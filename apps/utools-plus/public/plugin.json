{
  "pluginName": "uTools Plus",
  "description": "在 uTools 中补充 macOS 系统能力，包括设备连接、输出切换和常用系统快捷控制",
  "author": "liangkw16",
  "version": "1.1.0",
  "platform": [
    "darwin"
  ],
  "pluginSetting": {
    "single": true
  },
  "main": "index.html",
  "preload": "preload/services.js",
  "logo": "logo.png",
  "development": {
    "main": "http://127.0.0.1:5173/index.html"
  },
  "features": [
    {
      "code": "bluetooth",
      "explain": "管理 macOS 蓝牙设备连接和蓝牙开关",
      "cmds": [
        "蓝牙",
        "bluetooth",
        "Bluetooth"
      ]
    },
    {
      "code": "sound",
      "explain": "管理 macOS 音频输入和输出设备",
      "cmds": [
        "声音",
        "sound",
        "音频",
        "输入设备",
        "输出设备",
        "音量",
        "调节音量",
        "静音",
        "取消静音"
      ]
    },
    {
      "code": "wifi",
      "explain": "管理 macOS Wi-Fi 状态和附近无线网络",
      "cmds": [
        "Wi-Fi",
        "wifi",
        "无线网络",
        "网络"
      ]
    }
  ]
}
