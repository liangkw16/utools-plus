{
  "name": "utools-plus",
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev-utools.cjs",
    "dev:web": "vite --host 127.0.0.1",
    "build:helper": "node scripts/build-helper.cjs",
    "build": "npm run build:helper && vite build && node scripts/plugin-manifest.cjs",
    "test": "node --test public/preload/*.test.js public/preload/services/*.test.js src/modules/*/lib/*.test.js scripts/*.test.cjs"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^4.3.1",
    "standard": "^17.1.0",
    "utools-api-types": "^7.5.1",
    "vite": "^6.0.11"
  }
}
